{
  "manifest_version": 3,
  "name": "reCAPTCHA reload interceptor",
  "version": "0.1.0",
  "description": "Capture (et bloque optionnellement) le corps du POST /recaptcha/enterprise/reload pour diagnostic de score.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://www.google.com/recaptcha/*",
    "*://*.ticketmaster.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "reCAPTCHA reload interceptor"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.google.com/recaptcha/*",
        "*://*.ticketmaster.com/*"
      ],
      "js": ["inject.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    },
    {
      "matches": [
        "*://www.google.com/recaptcha/*",
        "*://*.ticketmaster.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "ISOLATED"
    }
  ]
}
